DATABASE_URL="postgresql://postgres:postgres@localhost:5432/silent_room?schema=public"
SHADOW_DATABASE_URL=""
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
UPLOAD_DIR="./storage/uploads"

# If you use `npm run db:dev`, copy the TCP URLs from `npm run db:dev:ls`.
# Add `statement_cache_size=0` to those URLs if Prisma Studio or db pull reports prepared statement conflicts.
